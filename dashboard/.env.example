# ODS Dashboard connections — copy to a file (e.g. ods.env), fill in, then in the app:
#   Settings -> Import .env file
# Only these keys are read; anything else is ignored. Blank values are skipped.
# Values may be quoted. Lines starting with # are comments.

# Vercel REST API token (deploy state)
VERCEL_TOKEN=

# GitHub personal access token, notifications scope (unread notifications + headlines)
GITHUB_PAT=

# Supabase project (health is keyless; URL defaults to the Link-Core project)
SUPABASE_URL=https://kfbtpcwakpyptwqqhabu.supabase.co
SUPABASE_ANON_KEY=

# Meta Graph API page access token (Facebook + Instagram)
META_PAGE_TOKEN=

# Telegram bot token from @BotFather (channel member count + bot health)
TELEGRAM_BOT_TOKEN=

# Google OAuth client ID for Gmail unread counts.
# After importing, still tap "Connect" next to the Gmail account in Settings.
GOOGLE_CLIENT_ID=
